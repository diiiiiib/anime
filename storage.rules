rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Allow authenticated users to upload avatars and debug files
    match /avatars/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /debug/{allPaths=**} {
      allow read, write: if request.auth != null;
    }

    // Default: allow read but deny writes
    match /{allPaths=**} {
      allow read: if true;
      allow write: if false;
    }
  }
}
