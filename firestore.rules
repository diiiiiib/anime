rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // -------------------------
    // Users collection
    // - المصادقة مطلوبة لقراءة/قوائم المستخدمين
    // - يمكن للمستخدم إنشاء/تحديث مستنده فقط (uid يطابق request.auth.uid)
    // -------------------------
    match /users/{userId} {
      allow read: if request.auth != null; // يشمل get و list
      allow create: if request.auth != null
                    && request.auth.uid == userId
                    && request.resource.data.name is string
                    && (request.resource.data.avatar is string || request.resource.data.avatar == null);
      allow update: if request.auth != null && request.auth.uid == userId;
      allow delete: if false;
    }

    // -------------------------
    // Conversations (مستندات المحادثات)
    // - كل مستند conversations/{convId} يحتوي على حقل participants: [uid1, uid2, ...]
    // - السماح بقراءة/كتابة المستند فقط للمشاركين
    // -------------------------
    match /conversations/{convId} {
      // إنشاء المحادثة مسموح إذا كان المرسل جزءاً من المشاركين المرسَلة
      allow create: if request.auth != null
                    && request.resource.data.participants is list
                    && request.auth.uid in request.resource.data.participants;

      // كل عمليات القراءة (get / list) والـ update للمستند مسموح للمشاركين فقط
      allow get, list, update: if request.auth != null && request.auth.uid in resource.data.participants;
      allow delete: if false;

      // -------------------------
      // Messages subcollection: conversations/{convId}/messages/{messageId}
      // - قراءة الرسائل مسموح للمشاركين
      // - إنشاء رسالة مسموح فقط للمشارك ويجب أن يكون authorId = request.auth.uid
      // -------------------------
      match /messages/{messageId} {
        allow read: if request.auth != null
                    && request.auth.uid in get(/databases/$(database)/documents/conversations/$(convId)).data.participants;

        allow create: if request.auth != null
                      && request.auth.uid == request.resource.data.authorId
                      && request.resource.data.text is string
                      && request.auth.uid in get(/databases/$(database)/documents/conversations/$(convId)).data.participants;

        // لا نسمح بالتعديل أو الحذف بعد الإنشاء عبر الواجهة
        allow update, delete: if false;
      }
    }

    // Temporary debug collection used by diagnostics tool
    // يسمح بإنشاء وقراءة مستندات الاختبار للمستخدمين المصادق عليهم أثناء التطوير
    match /debug_tests/{docId} {
      allow read, create, delete: if request.auth != null;
      allow update: if false;
    }

    // -------------------------
    // قواعد عامة افتراضية
    // - افتراضيًا لا نسمح بأي وصول آخر
    // -------------------------
  }
}
